{
  "name": "myrank-mobile",
  "version": "1.0.2",
  "main": "expo-router/entry",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^24.1.1",
    "@react-native-firebase/crashlytics": "^24.1.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/query-async-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.0",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.0",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.0",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.0",
    "expo-system-ui": "~6.0.0",
    "expo-video": "~3.0.16",
    "expo-video-thumbnails": "~10.0.8",
    "firebase": "^12.14.0",
    "nativewind": "^4.2.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-compressor": "^1.16.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run test && npm run lint",
    "start": "expo start --dev-client --lan",
    "start:tunnel": "expo start --dev-client --tunnel",
    "start:go": "expo start --go --lan --clear",
    "build:android": "bash scripts/build-android-apk.sh",
    "build:dev:local": "bash scripts/build-dev-apk.sh",
    "build:preview:local": "bash scripts/build-preview-apk.sh",
    "build:prod:local": "bash scripts/build-prod-local.sh",
    "build:setup-fcm": "node scripts/setup-expo-fcm-v1.js",
    "build:verify-env": "bash scripts/verify-build-env.sh",
    "build:dev:android": "bash scripts/verify-build-env.sh && npx eas-cli build -p android --profile development --non-interactive",
    "build:preview:android": "bash scripts/verify-build-env.sh && npx eas-cli build -p android --profile preview --non-interactive",
    "build:preview:ios": "bash scripts/verify-build-env.sh && npx eas-cli build -p ios --profile preview --non-interactive",
    "build:prod:android": "bash scripts/verify-build-env.sh && npx eas-cli build -p android --profile production --non-interactive",
    "build:prod:ios": "bash scripts/verify-build-env.sh && npx eas-cli build -p ios --profile production --non-interactive",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "private": true
}
