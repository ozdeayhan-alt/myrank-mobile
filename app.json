{
  "expo": {
    "name": "MyRank",
    "slug": "myrank-mobile",
    "owner": "myrank",
    "sdkVersion": "54.0.0",
    "version": "1.0.7",
    "jsEngine": "hermes",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "myrankmobile",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.myrank.mobile",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Profil fotoğrafı ve paylaşım için galeri erişimi gerekir.",
        "NSPhotoLibraryAddUsageDescription": "Profil fotoğrafı ve paylaşım için galeriye kaydetme erişimi gerekir.",
        "NSCameraUsageDescription": "Fotoğraf ve video çekmek için kamera erişimi gerekir.",
        "NSMicrophoneUsageDescription": "Video kaydı için mikrofon erişimi gerekir.",
        "NSUserNotificationUsageDescription": "Beğeni, yorum ve mesaj bildirimlerini almak için bildirim izni gerekir.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.myrank.mobile",
      "versionCode": 12,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#111827",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1f2b3602-e7e1-4bef-ac27-861db8486268"
      }
    }
  }
}
