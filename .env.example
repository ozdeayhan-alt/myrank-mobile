# Firebase Web App config (Firebase Console > Project settings > Your apps > Web app)
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=myrankapp-d62b9.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=myrankapp-d62b9
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=myrankapp-d62b9.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# Backend API (myrankapp Express)
# Production (HTTPS):         https://myrank.com.tr
# Play Console privacy URL:   https://myrank.com.tr/privacy
EXPO_PUBLIC_API_URL=https://myrank.com.tr

# Optional CDN proxy (disabled — Firebase paths need %2F encoding fix on nginx first)
# EXPO_PUBLIC_MEDIA_PROXY_ORIGIN=https://myrank.com.tr

# Reels: MP4 first (legacy HLS compatibility); new uploads may still use HLS as fallback
EXPO_PUBLIC_REELS_HLS_FIRST=false

# Google Sign-In (Firebase Console > Authentication > Google > Web client ID)
# Android için EAS keystore SHA-1 fingerprint'i Firebase'e ekleyin.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# Expo push (expo.dev project ID — eas project:info ile alınır)
EXPO_PUBLIC_EAS_PROJECT_ID=1f2b3602-e7e1-4bef-ac27-861db8486268

# Build variant (development | preview | production)
# Yerel preview APK:  npm run build:preview:local
# EAS preview cloud:  npm run build:preview:android  (eas login gerekir)
# EAS env yükleme:      eas env:create --name EXPO_PUBLIC_API_URL --value ... --environment preview
APP_VARIANT=development
