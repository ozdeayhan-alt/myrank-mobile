{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_API_URL": "https://myrank.com.tr",
        "EXPO_PUBLIC_MEDIA_PROXY_ORIGIN": "https://myrank.com.tr",
        "EXPO_PUBLIC_REELS_HLS_FIRST": "false"
      },
      "android": {
        "buildType": "apk",
        "image": "latest"
      },
      "ios": {
        "simulator": false,
        "image": "latest"
      }
    },
    "staging": {
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_API_URL": "https://staging.myrank.com.tr",
        "EXPO_PUBLIC_MEDIA_PROXY_ORIGIN": "https://staging.myrank.com.tr",
        "EXPO_PUBLIC_REELS_HLS_FIRST": "true"
      },
      "android": {
        "buildType": "apk",
        "image": "latest"
      },
      "ios": {
        "simulator": false,
        "image": "latest"
      }
    },
    "production": {
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_API_URL": "https://myrank.com.tr",
        "EXPO_PUBLIC_MEDIA_PROXY_ORIGIN": "https://myrank.com.tr",
        "EXPO_PUBLIC_REELS_HLS_FIRST": "false"
      },
      "android": {
        "buildType": "app-bundle",
        "image": "latest",
        "autoIncrement": "versionCode"
      },
      "ios": {
        "simulator": false,
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
